# OpenAI API key (required)
OPENAI_API_KEY=

# Output directories (optional; defaults shown)
# Image: ~/Pictures/openai-images
# Audio: ~/Music/openai-audio
OPENAI_IMAGE_OUTPUT_DIR=
OPENAI_AUDIO_OUTPUT_DIR=

# Model defaults (optional; can also be overridden per tool call)
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_MODERATION_MODEL=omni-moderation-latest
